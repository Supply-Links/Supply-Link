# ─────────────────────────────────────────────────────────────────────────────
# Supply-Link — Root Workspace Environment Variables
# These are used by CI/CD workflows and deployment scripts.
# Copy to .env and fill in values. NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub personal access token — used by semantic-release to create releases.
# Required for release workflow. Generate at: https://github.com/settings/tokens
# Scopes needed: repo, write:packages
# GITHUB_TOKEN=

# Stellar secret key for testnet contract deployment (CI use only).
# Fund the account with Friendbot before use: https://friendbot.stellar.org
# Required: only for deploy-testnet workflow
# STELLAR_SECRET_KEY=

# Vercel deployment token — used by Vercel GitHub integration.
# Generate at: https://vercel.com/account/tokens
# Required: only for Vercel deployment workflow
# VERCEL_TOKEN=
