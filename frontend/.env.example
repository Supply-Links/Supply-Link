# ─────────────────────────────────────────────────────────────────────────────
# Supply-Link Frontend — Environment Variables
# Copy this file to .env.local and fill in the values for your environment.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Soroban smart contract address on the target network.
# Testnet default is the publicly deployed Supply-Link contract.
# Required: yes
NEXT_PUBLIC_CONTRACT_ID=CBUWSKT2UGOAXK4ZREVDJV5XHSYB42PZ3CERU2ZFUTUMAZLJEHNZIECA

# Target Stellar network. Accepted values: testnet | mainnet
# Controls which RPC URL and network passphrase are used automatically.
# Required: yes
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC endpoint. Override only if you run a private RPC node.
# Defaults are set in lib/stellar/client.ts based on NEXT_PUBLIC_STELLAR_NETWORK.
# Required: no (auto-derived from NEXT_PUBLIC_STELLAR_NETWORK)
# NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase. Override only if you use a custom network.
# Required: no (auto-derived from NEXT_PUBLIC_STELLAR_NETWORK)
# NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
